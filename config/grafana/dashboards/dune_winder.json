          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"x_velocity\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "legendFormat": "X velocity (mm/s)",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"y_velocity\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "legendFormat": "Y velocity (mm/s)",
          "refId": "B"
        },
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"z_velocity\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "legendFormat": "Z velocity (mm/s)",

EQU(MOVE_TYPE,9)XIC(INIT_SW)OTU(INIT_SW);   XIC(INIT_SW)TON(TIMER,?,?);   XIO(INIT_SW)CPT(MOVE_TYPE,0)OTL(INIT_SW);   XIC(TIMER.DN)OSR(SetBit[0],OutBit[0]);   XIC(OutBit[0])CPT(MOVE_TYPE,0)CPT(NEXTSTATE,1)CPT(STATE,0)CPT(ERROR_CODE,0);   XIC(OutBit[0])OTU(LATCH_ACTUATOR_HOMED);   XIC(SetBit[0])OTE(INIT_DONE);   XIC(INIT_DONE)CMP(STATE=0)MAFR(Z_axis,Z_AXIS_STAT[0]);   XIC(Z_AXIS_STAT[0].DN)OSR(SetBit[1],OutBit[1]);   XIC(OutBit[1])CPT(NEXTSTATE,1);   ;   
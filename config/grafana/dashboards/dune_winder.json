{
  "__inputs": [],
  "__requires": [
    { "type": "grafana",    "id": "grafana",   "name": "Grafana",   "version": "9.0.0" },
    { "type": "datasource", "id": "influxdb",  "name": "InfluxDB",  "version": "1.0.0" },
    { "type": "panel",      "id": "timeseries","name": "Time series","version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "id": 1,
      "title": "Tension",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never"
          },
          "unit": "short",
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"tension\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "XYZ Velocity Setpoint (v_xyz)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never"
          },
          "unit": "velocityms",
          "min": 0,
          "max": 1100
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"v_xyz\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Tension Motor CV",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never"
          },
          "unit": "short",
          "min": 0,
          "max": 10
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["last", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"tension_motor_cv\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Axis Positions",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never"
          },
          "unit": "lengthmm"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "X position (mm)" },
            "properties": [{ "id": "custom.axisPlacement", "value": "left" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Y.*|Z.*" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"x_position\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "legendFormat": "X position (mm)",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"y_position\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "legendFormat": "Y position (mm)",
          "refId": "B"
        },
        {
          "datasource": { "type": "influxdb", "uid": "dune-influxdb" },
          "query": "from(bucket: \"winder\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"plc_tags\")\n  |> filter(fn: (r) => r[\"_field\"] == \"z_position\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "legendFormat": "Z position (mm)",
          "refId": "C"
        }
      ]
    },

    {
      "id": 5,
      "title": "Axis Velocities",
      "type": "timeseries",

XIC(INIT_DONE)CMP(STATE=1)OTE(STATE1_IND);   XIC(STATE1_IND)OSR(trigger_axes_sb,trigger_axes_ob);   XIC(trigger_axes_ob)XIO(dont_auto_trigger_axes_in_state_1)MSO(X_axis,x_on_mso)MSO(Y_axis,y_on_mso)MSO(Z_axis,z_on_mso);   XIC(STATE1_IND)MOV(0,ERROR_CODE);   XIC(STATE1_IND)CMP(MOVE_TYPE=1)OSR(SetBit[0],OutBit[0]);   XIC(OutBit[0])CPT(NEXTSTATE,2);   XIC(STATE1_IND)CMP(MOVE_TYPE=2)OSR(SetBit[1],OutBit[1]);   XIC(OutBit[1])CPT(NEXTSTATE,3);   XIC(STATE1_IND)CMP(MOVE_TYPE=3)OSR(SetBit[2],OutBit[2]);   XIC(OutBit[2])CPT(NEXTSTATE,4);   XIC(STATE1_IND)CMP(MOVE_TYPE=4)OSR(SetBit[3],OutBit[3]);   XIC(OutBit[3])CPT(NEXTSTATE,5);   XIC(STATE1_IND)CMP(MOVE_TYPE=5)OSR(SetBit[4],OutBit[4]);   XIC(OutBit[4])CPT(NEXTSTATE,6);   XIC(STATE1_IND)CMP(MOVE_TYPE=6)OSR(SetBit[5],OutBit[5]);   XIC(OutBit[5])CPT(NEXTSTATE,7);   XIC(STATE1_IND)CMP(MOVE_TYPE=7)OSR(SetBit[6],OutBit[6]);   XIC(OutBit[6])CPT(NEXTSTATE,8);   XIC(STATE1_IND)CMP(MOVE_TYPE=8)OSR(SetBit[7],OutBit[7]);   XIC(OutBit[7])CPT(NEXTSTATE,9);   ;   